# ─── CMD: run single phase ────────────────────────────────────────────────────
cmd_phase() {
    require_root
    local n="${1:-}"
    if [[ -z "$n" ]] || ! [[ "$n" =~ ^[0-9]+$ ]] || (( n < 1 || n > 18 )); then
        error "Usage: sudo forge phase <1-18>"
        echo ""
        cmd_help
        exit 1
    fi

    PHASES_RUN=("$n")

    # For phases that need runtime vars, prompt only what's needed
    case "$n" in
        1) ask SERVER_HOSTNAME "Hostname" "vps-server"; ask SERVER_TIMEZONE "Timezone" "UTC" ;;
        2) ask ADMIN_USER "Admin username" "deploy" ;;
        3) ask ADMIN_USER "Admin username" "deploy"
           ask SSH_PORT "SSH port" "2222"
           read_ssh_pubkey ;;
        4) ask SSH_PORT "SSH port in use" "2222"
           echo -e "  ${C}?${RESET} ${W}Extra ports (space-separated, blank=none)${RESET}:"
           echo -en "  ${D}> ${RESET}"; read -r -a EXTRA_PORTS
           confirm "Open Docker Swarm ports?" "n" && OPEN_SWARM=true || OPEN_SWARM=false ;;
        5) ask SSH_PORT "SSH port in use" "2222" ;;
        10) ask DOMAIN "Root domain" "" ;;
    esac

    echo ""
    case "$n" in
        1)  phase_system_update  ;;
        2)  phase_create_user    ;;
        3)  phase_ssh_hardening  ;;
        4)  phase_ufw            ;;
        5)  phase_fail2ban       ;;
        6)  phase_kernel_hardening ;;
        7)  phase_rootkit        ;;
        8)  phase_auto_updates   ;;
        9)  phase_docker         ;;
        10) phase_caprover       ;;
        11) phase_monitoring     ;;
        12) phase_lynis          ;;
        13) phase_backup         ;;
        14) phase_swap           ;;
        15) phase_zsh            ;;
        16) phase_notifications  ;;
        17) phase_wireguard      ;;
        18) phase_heal           ;;
    esac
}

# ─── PHASE: Swap File ────────────────────────────────────────────────────────
phase_swap() {
    banner "Phase 14 · Swap File"

    if [[ -n "$(swapon --show)" ]]; then
        ok "Swap is already enabled — skipping"
        return 0
    fi

    local ram_kb
    ram_kb=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    local ram_mb=$((ram_kb / 1024))
    local swap_size="2G"

    if [ "$ram_mb" -le 1024 ]; then
        swap_size="2G"
    elif [ "$ram_mb" -le 2048 ]; then
        swap_size="4G"
    else
        swap_size="2G"
    fi

    info "Creating ${swap_size} swap file..."
    fallocate -l "$swap_size" /swapfile >> "$LOG_FILE" 2>&1 || {
        warn "fallocate failed, attempting dd..."
        dd if=/dev/zero of=/swapfile bs=1M count=$(( ${swap_size%G} * 1024 )) >> "$LOG_FILE" 2>&1
    }

    chmod 600 /swapfile
    mkswap /swapfile >> "$LOG_FILE" 2>&1
    swapon /swapfile >> "$LOG_FILE" 2>&1

    if ! grep -q "/swapfile" /etc/fstab; then
        echo "/swapfile none swap sw 0 0" >> /etc/fstab
    fi

    # Optimize swappiness
    sysctl vm.swappiness=10 >> "$LOG_FILE" 2>&1
    echo "vm.swappiness=10" >> /etc/sysctl.conf

    ok "Swap file (${swap_size}) created and optimized"
    ok "Phase 14 complete"
}

# ─── PHASE: Developer Experience (Zsh) ───────────────────────────────────────
phase_zsh() {
    banner "Phase 15 · Developer Experience (Zsh)"
    local target_user="${ADMIN_USER:-deploy}"

    if ! id "$target_user" &>/dev/null; then
        warn "User '${target_user}' does not exist. Configuring for current user."
        target_user=$(whoami)
    fi

    DEBIAN_FRONTEND=noninteractive run apt-get install -y zsh curl git

    info "Configuring Zsh for ${target_user}..."
    local user_home
    user_home=$(eval echo "~$target_user")

    # Install Oh-My-Zsh if not already present
    if [[ ! -d "${user_home}/.oh-my-zsh" ]]; then
        info "Installing Oh-My-Zsh..."
        sudo -u "$target_user" sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended >> "$LOG_FILE" 2>&1
    fi

    # Install plugins
    local plugin_dir="${user_home}/.oh-my-zsh/custom/plugins"
    mkdir -p "$plugin_dir"

    if [[ ! -d "${plugin_dir}/zsh-autosuggestions" ]]; then
        sudo -u "$target_user" git clone https://github.com/zsh-users/zsh-autosuggestions "$plugin_dir/zsh-autosuggestions" >> "$LOG_FILE" 2>&1
    fi
    if [[ ! -d "${plugin_dir}/zsh-syntax-highlighting" ]]; then
        sudo -u "$target_user" git clone https://github.com/zsh-users/zsh-syntax-highlighting "$plugin_dir/zsh-syntax-highlighting" >> "$LOG_FILE" 2>&1
    fi

    # Update .zshrc
    sudo -u "$target_user" sed -i 's/plugins=(git)/plugins=(git zsh-autosuggestions zsh-syntax-highlighting)/' "${user_home}/.zshrc"

    # Change shell
    chsh -s "$(which zsh)" "$target_user" >> "$LOG_FILE" 2>&1

    ok "Zsh with Oh-My-Zsh & plugins configured for ${target_user}"
    ok "Phase 15 complete"
}

# ─── CMD: Shell ───────────────────────────────────────────────────────────────
cmd_shell() {
    require_root shell
    local target_user="${1:-deploy}"

    if ! id "$target_user" &>/dev/null; then
        error "User '${target_user}' not found."
        echo -e "  ${D}Usage: sudo forge shell [username]${RESET}"
        return 1
    fi

    banner "Shell Configuration: ${target_user}"
    echo -e "  ${D}Current shell:${RESET} ${W}$(getent passwd "$target_user" | cut -d: -f7)${RESET}"
    echo ""

    echo -e "  ${C}[b]${RESET} Switch to Bash"
    echo -e "  ${C}[z]${RESET} Switch to Zsh"
    echo -e "  ${C}[o]${RESET} Install/Update Oh-My-Zsh & Plugins"
    echo ""
    echo -en "  ${C}?${RESET} ${W}Your choice${RESET}: "
    read -r choice

    case "$choice" in
        [Bb]*)
            chsh -s "$(which bash)" "$target_user" && ok "Shell changed to Bash for ${target_user}" ;;
        [Zz]*)
            apt-get install -y zsh &>/dev/null
            chsh -s "$(which zsh)" "$target_user" && ok "Shell changed to Zsh for ${target_user}" ;;
        [Oo]*)
            ADMIN_USER="$target_user" phase_zsh ;;
        *)
            echo -e "  ${D}Cancelled.${RESET}" ;;
    esac
}

# ─── PHASE: Webhook Notifications ──────────────────────────────────────────
send_notification() {
    local message="$1"
    [[ -z "$WEBHOOK_URL" ]] && return 0

    local payload=""
    case "$WEBHOOK_TYPE" in
        slack)   payload="{\"text\": \"${message}\"}" ;;
        discord) payload="{\"content\": \"${message}\"}" ;;
        telegram)
            # Telegram format: URL should be https://api.telegram.org/bot<token>/sendMessage?chat_id=<id>
            curl -s -X POST "$WEBHOOK_URL" -d "text=${message}" >> "$LOG_FILE" 2>&1
            return 0
            ;;
    esac

    curl -s -X POST -H 'Content-type: application/json' --data "$payload" "$WEBHOOK_URL" >> "$LOG_FILE" 2>&1
}

phase_notifications() {
    banner "Phase 16 · Webhook Notifications"

    if [[ -z "$WEBHOOK_URL" ]]; then
        warn "Webhook URL not configured — skipping"
        return 0
    fi

    # Save to config if not present
    mkdir -p "$CONFIG_DIR"
    echo "WEBHOOK_URL=\"$WEBHOOK_URL\"" > "${CONFIG_DIR}/notifications.conf"
    echo "WEBHOOK_TYPE=\"$WEBHOOK_TYPE\"" >> "${CONFIG_DIR}/notifications.conf"

    send_notification "🔔 *Forge v${VERSION}*: Notifications enabled for *$(hostname)*"
    ok "Notifications enabled and test sent (${WEBHOOK_TYPE})"
    ok "Phase 16 complete"
}

# ─── PHASE: WireGuard VPN ─────────────────────────────────────────────────────
phase_wireguard() {
    banner "Phase 17 · WireGuard VPN"

    DEBIAN_FRONTEND=noninteractive run apt-get install -y wireguard qrencode iptables

    local wg_dir="/etc/wireguard"
    mkdir -p "$wg_dir" && chmod 700 "$wg_dir"

    info "Generating keys..."
    local server_priv server_pub client_priv client_pub
    server_priv=$(wg genkey)
    server_pub=$(echo "$server_priv" | wg pubkey)
    client_priv=$(wg genkey)
    client_pub=$(echo "$client_priv" | wg pubkey)

    local public_ip
    public_ip=$(hostname -I | awk '{print $1}')
    local eth_int
    eth_int=$(ip route get 8.8.8.8 | grep -Po '(?<=dev )(\S+)')

    info "Configuring server (wg0)..."
    cat > "${wg_dir}/wg0.conf" <<WGOEOF
[Interface]
PrivateKey = ${server_priv}
Address = 10.0.0.1/24
ListenPort = 51820
PostUp = iptables -A FORWARD -i wg0 -j ACCEPT; iptables -t nat -A POSTROUTING -o ${eth_int} -j MASQUERADE
PostDown = iptables -D FORWARD -i wg0 -j ACCEPT; iptables -t nat -D POSTROUTING -o ${eth_int} -j MASQUERADE

[Peer]
PublicKey = ${client_pub}
AllowedIPs = 10.0.0.2/32
WGOEOF

    # Enable IP forwarding
    echo "net.ipv4.ip_forward=1" > /etc/sysctl.d/99-wireguard.conf
    sysctl -p /etc/sysctl.d/99-wireguard.conf >> "$LOG_FILE" 2>&1

    # UFW integration
    if command -v ufw &>/dev/null; then
        ufw allow 51820/udp comment "WireGuard" >> "$LOG_FILE" 2>&1
    fi

    systemctl enable wg-quick@wg0 >> "$LOG_FILE" 2>&1
    systemctl start wg-quick@wg0 >> "$LOG_FILE" 2>&1

    # Generate client config
    cat > "/root/wireguard-client.conf" <<WGOEOF
[Interface]
PrivateKey = ${client_priv}
Address = 10.0.0.2/24
DNS = 1.1.1.1, 8.8.8.8

[Peer]
PublicKey = ${server_pub}
Endpoint = ${public_ip}:51820
AllowedIPs = 0.0.0.0/0
PersistentKeepalive = 25
WGOEOF

    ok "WireGuard server running on port 51820"
    echo ""
    echo -e "  ${G}${BOLD}CLIENT CONFIG GENERATED!${RESET}"
    echo -e "  ${D}Saved to:${RESET} ${W}/root/wireguard-client.conf${RESET}"
    echo ""
    echo -e "  ${W}Scan this with your WireGuard mobile app:${RESET}"
    echo ""
    qrencode -t ansiutf8 < "/root/wireguard-client.conf"
    echo ""

    ok "Phase 17 complete"
}

# ─── PHASE: Automated Heal ────────────────────────────────────────────────────
phase_heal() {
    banner "Phase 18 · Automated Heal System"

    local heal_script="/usr/local/bin/forge-heal"
    info "Installing heal engine to ${heal_script}..."

    cat > "$heal_script" <<'HEALEOF'
#!/usr/bin/env bash
# Forge Automated Heal Engine
LOG_FILE="/var/log/forge/heal.log"
CONFIG="/etc/forge/notifications.conf"

notify() {
    [[ -f "$CONFIG" ]] && source "$CONFIG"
    [[ -z "${WEBHOOK_URL:-}" ]] && return 0
    local msg="🛠 *Forge Heal*: $1"
    case "${WEBHOOK_TYPE:-slack}" in
        slack)   curl -s -X POST -H 'Content-type: application/json' --data "{\"text\": \"$msg\"}" "$WEBHOOK_URL" >/dev/null ;;
        discord) curl -s -X POST -H 'Content-type: application/json' --data "{\"content\": \"$msg\"}" "$WEBHOOK_URL" >/dev/null ;;
        telegram) curl -s -X POST "$WEBHOOK_URL" -d "text=$msg" >/dev/null ;;
    esac
}

check_service() {
    local svc=$1
    if ! systemctl is-active --quiet "$svc"; then
        echo "$(date) - $svc is down. Restarting..." >> "$LOG_FILE"
        systemctl restart "$svc"
        notify "Restarted failing service: *$svc* on *$(hostname)*"
    fi
}

# Core Services
check_service ssh
command -v docker &>/dev/null && check_service docker
systemctl list-unit-files | grep -q "wg-quick@wg0" && check_service wg-quick@wg0

# CapRover
if docker ps 2>/dev/null | grep -q caprover; then
    if ! curl -s --max-time 10 http://localhost:3000 >/dev/null; then
        echo "$(date) - CapRover API unresponsive. Restarting container..." >> "$LOG_FILE"
        docker restart caprover >/dev/null
        notify "Restarted unresponsive *CapRover* container on *$(hostname)*"
    fi
fi
HEALEOF

    chmod +x "$heal_script"

    info "Setting up systemd timer (every 5 mins)..."
    cat > /etc/systemd/system/forge-heal.service <<SEEOF
[Unit]
Description=Forge Automated Heal Service

[Service]
Type=oneshot
ExecStart=${heal_script}
SEEOF

    cat > /etc/systemd/system/forge-heal.timer <<TEEOF
[Unit]
Description=Run Forge Heal every 5 minutes

[Timer]
OnBootSec=2min
OnUnitActiveSec=5min

[Install]
WantedBy=timers.target
TEEOF

    systemctl daemon-reload
    systemctl enable --now forge-heal.timer >> "$LOG_FILE" 2>&1

    ok "Heal system active (background monitoring every 5m)"
    ok "Phase 18 complete"
}

# ─── CMD: Heal ────────────────────────────────────────────────────────────────
cmd_heal() {
    require_root heal
    banner "Manual System Health Check"
    info "Running heal engine..."
    /usr/local/bin/forge-heal
    ok "Health check completed. Check /var/log/forge/heal.log for details."
}

# ─── CMD: full wizard run ─────────────────────────────────────────────────────
cmd_run() {
    require_root
    log "forge v${VERSION} started — full run"
    splash
    pause
    phase_menu
    gather_config

    echo ""
    echo -e "  ${G}${BOLD}Starting...${RESET}\n"

    # Send start notification if configured
    if [[ -n "$WEBHOOK_URL" ]]; then
        send_notification "🚀 *Forge*: Starting setup on *$(hostname)*"
    fi

    has_phase 1  && phase_system_update
    has_phase 2  && phase_create_user
    has_phase 3  && phase_ssh_hardening
    has_phase 4  && phase_ufw
    has_phase 5  && phase_fail2ban
    has_phase 6  && phase_kernel_hardening
    has_phase 7  && phase_rootkit
    has_phase 8  && phase_auto_updates
    has_phase 9  && phase_docker
    has_phase 10 && ${INSTALL_CAPROVER:-false} && phase_caprover
    has_phase 11 && phase_monitoring
    has_phase 12 && phase_lynis
    has_phase 13 && phase_backup
    has_phase 14 && phase_swap
    has_phase 15 && phase_zsh
    has_phase 16 && phase_notifications
    has_phase 17 && phase_wireguard
    has_phase 18 && phase_heal

    print_summary

    if [[ -n "$WEBHOOK_URL" ]]; then
        send_notification "✅ *Forge*: Setup completed successfully on *$(hostname)*"
    fi
    log "forge completed"
}

# ─── ROUTER ───────────────────────────────────────────────────────────────────
case "${1:-run}" in
    run)       cmd_run ;;
    phase)     shift; cmd_phase "$@" ;;
    status)    cmd_status ;;
    shell)     shift; cmd_shell "$@" ;;
    logs)      cmd_logs ;;
    reset)     cmd_reset ;;
    update)    cmd_update ;;
    uninstall) cmd_uninstall ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help)       cmd_help ;;
    *)
        error "Unknown command: ${1}"
        echo ""
        cmd_help
        exit 1
        ;;
esac
