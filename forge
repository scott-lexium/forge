# ─── STATUS ───────────────────────────────────────────────────────────────────
cmd_status() {
    banner "Server Hardening Status"

    _check() {
        local label=$1 cmd=$2
        if eval "$cmd" &>/dev/null 2>&1; then
            echo -e "  ${OK} ${label}"
        else
            echo -e "  ${ERR} ${R}${label}${RESET}"
        fi
    }

    _val() {
        local label=$1; shift
        local value
        value=$(eval "$@" 2>/dev/null || echo "unknown")
        echo -e "  ${ARROW} ${D}${label}:${RESET} ${W}${value}${RESET}"
    }

    echo -e "  ${W}System${RESET}"
    _val "Version"       "echo v${VERSION} (${CHANNEL})"
    _val "Hostname"      "hostname"
    _val "OS"            "lsb_release -ds 2>/dev/null || cat /etc/os-release | grep PRETTY_NAME | cut -d= -f2 | tr -d '\"'"
    _val "Uptime"        "uptime -p"
    _val "Kernel"        "uname -r"
    _val "Swap"          "free -h | awk '/Swap/ {print \$3 \" used of \" \$2}'"
    echo ""

    echo -e "  ${W}Security${RESET}"
    _check "UFW firewall active"         "ufw status | grep -q 'Status: active'"
    _check "Fail2ban running"            "systemctl is-active fail2ban"
    _check "Unattended upgrades enabled" "systemctl is-active unattended-upgrades"
    _check "Root login disabled (SSH)"   "grep -q '^PermitRootLogin no' /etc/ssh/sshd_config"
    _check "Password auth disabled (SSH)" "grep -q '^PasswordAuthentication no' /etc/ssh/sshd_config"
    echo ""

    echo -e "  ${W}Services${RESET}"
    _check "Docker running"              "systemctl is-active docker"
    _check "SSH service running"         "systemctl is-active ssh"
    if systemctl is-active --quiet ssh.socket; then
        echo -e "  ${Y}⚠ SSH Socket is ACTIVE (may ignore sshd_config port)${RESET}"
    else
        echo -e "  ${OK} SSH persistent service is in control${RESET}"
    fi
    _check "CapRover container"          "docker ps 2>/dev/null | grep -q caprover"
    _check "WireGuard VPN active"        "systemctl is-active wg-quick@wg0"
    _check "Automated Heal active"       "systemctl is-active forge-heal.timer"
    echo ""

    echo -e "  ${W}SSH Config${RESET}"
    local sshport
    sshport=$(grep -E '^Port ' /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | head -n 1)
    sshport=${sshport:-22}
    _val "Configured SSH port" "echo $sshport"

    if [[ -n "$(command -v ufw)" ]] && ufw status | grep -q 'Status: active'; then
        if ufw status | grep -E "^$sshport/tcp\s+ALLOW" >/dev/null; then
             echo -e "  ${OK} ${G}Firewall allows port $sshport${RESET}"
        else
             echo -e "  ${ERR} ${R}Firewall BLOCKS port $sshport${RESET}"
        fi

        # Check for port 22 if it's not the configured port
        if [[ "$sshport" != "22" ]] && ufw status | grep -E "^22/tcp\s+ALLOW" >/dev/null; then
            echo -e "  ${Y}⚠  Warning: Port 22 is still open in firewall (should be closed)${RESET}"
        fi
    fi
    echo ""

    echo -e "  ${W}Open Ports${RESET}"
    if command -v ss &>/dev/null; then
        ss -tulpn 2>/dev/null | grep LISTEN | awk '{print "  " $5}' | sort -u
    fi
    echo ""

    echo -e "  ${W}Disk & Memory${RESET}"
    df -h / | awk 'NR==2{printf "  '"${ARROW}"' Disk:    '"${W}"'%s used'"${RESET}"' of %s\n", $3, $2}'
    free -h | awk 'NR==2{printf "  '"${ARROW}"' Memory:  '"${W}"'%s used'"${RESET}"' of %s\n", $3, $2}'
    echo ""
}

# ─── UPDATE ───────────────────────────────────────────────────────────────────
cmd_update() {
    require_root update
    banner "Self-Update"

    local target_channel="${CHANNEL}"
    if [[ "${1:-}" == "--canary" ]]; then
        target_channel="canary"
    elif [[ "${1:-}" == "--stable" ]]; then
        target_channel="stable"
    fi

    local update_url="https://raw.githubusercontent.com/scott-lexium/forge/${target_channel}/forge"
    info "Fetching from channel: ${target_channel}..."

    local tmp
    tmp=$(mktemp)

    if curl -fsSL "$update_url" -o "$tmp" 2>>"$LOG_FILE"; then
        local remote_version
        local remote_channel
        remote_version=$(grep '^VERSION=' "$tmp" | head -1 | cut -d'"' -f2)
        remote_channel=$(grep '^CHANNEL=' "$tmp" | head -1 | cut -d'"' -f2)

        if [[ "$remote_version" == "$VERSION" && "$remote_channel" == "$CHANNEL" ]]; then
            ok "Already on the latest version (${VERSION}) of ${CHANNEL} channel."
            rm -f "$tmp"
            return
        fi

        info "Updating ${CHANNEL}/${VERSION} → ${remote_channel}/${remote_version}..."
        chmod +x "$tmp"
        mv "$tmp" "$INSTALL_PATH"
        ok "Updated successfully."
        note "Run: forge status — to confirm"
    else
        error "Could not reach GitHub or channel '${target_channel}' not found."
        rm -f "$tmp"
        return 1
    fi
}

