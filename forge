# ─── Helpers ──────────────────────────────────────────────────────────────────
log()     { echo "$(date '+%H:%M:%S') $*" >> "$LOG_FILE" 2>&1; }
banner()  {
    echo ""
    echo -e "${C}┌─────────────────────────────────────────────────────────────┐${RESET}"
    echo -e "${C}│${RESET}  ${BOLD}${W}$1${RESET}$(printf '%*s' $((58 - ${#1})) '')${C}│${RESET}"
    echo -e "${C}└─────────────────────────────────────────────────────────────┘${RESET}"
    echo ""
}
section() { echo -e "\n${M}━━━  $1  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}\n"; }
info()    { echo -e "  ${ARROW} ${W}$1${RESET}"; log "INFO: $1"; }
ok()      { echo -e "  ${OK} $1"; log "OK: $1"; }
warn()    { echo -e "  ${Y}⚠${RESET}  ${Y}$1${RESET}"; log "WARN: $1"; }
error()   { echo -e "  ${ERR} ${R}$1${RESET}"; log "ERROR: $1"; }
note()    { echo -e "  ${D}   $1${RESET}"; }
skip()    { echo -e "  ${SKIP} ${D}Skipped: $1${RESET}"; log "SKIP: $1"; }

run() {
    log "RUN: $*"
    if ! "$@" >> "$LOG_FILE" 2>&1; then
        error "Command failed: $*"
        echo -e "  ${D}See $LOG_FILE for details${RESET}"
        return 1
    fi
}

ask() {
    local var=$1 prompt=$2 default=${3:-""}
    local hint=""
    [[ -n "$default" ]] && hint=" ${D}[${default}]${RESET}"
    echo -en "  ${C}?${RESET} ${W}${prompt}${RESET}${hint}: "
    read -r input
    [[ -z "$input" && -n "$default" ]] && input="$default"
    eval "$var=\"$input\""
}

confirm() {
    local prompt=$1 default=${2:-"y"}
    local hint
    [[ "$default" == "y" ]] && hint="${G}Y${RESET}/${D}n${RESET}" || hint="${D}y${RESET}/${G}N${RESET}"
    echo -en "  ${C}?${RESET} ${W}${prompt}${RESET} [${hint}]: "
    read -r ans
    [[ -z "$ans" ]] && ans="$default"
    [[ "$ans" =~ ^[Yy] ]]
}

pause() {
    echo ""
    echo -en "  ${D}Press ${RESET}${W}Enter${RESET}${D} to continue...${RESET}"
    read -r
}

read_ssh_pubkey() {
    while true; do
        echo -e "  ${C}?${RESET} ${W}Paste your SSH public key${RESET} ${D}(cat ~/.ssh/id_ed25519.pub on local machine)${RESET}"
        echo -en "  ${D}> ${RESET}"
        read -r SSH_PUB_KEY
        echo ""
        if [[ -z "$SSH_PUB_KEY" ]]; then
            warn "No key entered."
            note "To generate one on your local machine: ssh-keygen -t ed25519"
        elif [[ ! "$SSH_PUB_KEY" =~ ^(ssh-|ecdsa-|sk-) ]]; then
            warn "That doesn't look like a valid SSH public key."
            note "Expected format: ssh-ed25519 AAAA...  (or ssh-rsa, ecdsa-sha2-*, etc.)"
        else
            return 0
        fi
        echo ""
        echo -en "  ${D}Try again? [${RESET}${G}Y${RESET}${D}/n]: ${RESET}"
        read -r _retry
        [[ "$_retry" =~ ^[Nn] ]] && { error "SSH public key is required for Phase 3. Aborting."; exit 1; }
        echo ""
    done
}

require_root() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "\n${R}  ✘ This command must be run as root.${RESET}"
        echo -e "  Run: ${W}sudo ${TOOL_NAME} $*${RESET}\n"
        exit 1
    fi
}

has_phase() {
    local p
    for p in "${PHASES_RUN[@]}"; do
        [[ "$p" == "$1" ]] && return 0
    done
    return 1
}

