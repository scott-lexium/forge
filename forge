# ─── GATHER CONFIG ────────────────────────────────────────────────────────────
gather_config() {
    section "Configuration"
    echo -e "  ${D}Collecting information before making any changes.\n${RESET}"

    local current_ssh_port
    current_ssh_port=$(grep -E "^Port " /etc/ssh/sshd_config 2>/dev/null | awk "{print \$2}" || echo "22")

    if has_phase 2 || has_phase 3; then
        ask ADMIN_USER "Admin username to create" "deploy"
        echo ""
    fi

    if has_phase 3; then
        ask SSH_PORT "New SSH port" "2222"
        echo ""
    fi

    if has_phase 3; then
        read_ssh_pubkey
    fi

    if has_phase 16; then
        ask WEBHOOK_URL "Webhook URL (Slack/Discord/Telegram)" ""
        if [[ -n "$WEBHOOK_URL" ]]; then
            echo -e "  ${C}?${RESET} ${W}Select Webhook Type${RESET}:"
            echo -e "    ${C}[s]${RESET} Slack"
            echo -e "    ${C}[d]${RESET} Discord"
            echo -e "    ${C}[t]${RESET} Telegram"
            echo -en "  ${C}?${RESET} ${W}Your choice${RESET} [${G}s${RESET}/d/t]: "
            read -r type
            case "${type,,}" in
                d*) WEBHOOK_TYPE="discord" ;;
                t*) WEBHOOK_TYPE="telegram" ;;
                *)  WEBHOOK_TYPE="slack" ;;
            esac
        fi
        echo ""
    fi

    if has_phase 1; then
        ask SERVER_HOSTNAME "Server hostname" "vps-server"
        ask SERVER_TIMEZONE "Timezone" "UTC"
        echo ""
    fi

    if has_phase 4 || has_phase 5; then
        # If we didn't run phase 3, make sure SSH_PORT is set to current
        if ! has_phase 3; then
            SSH_PORT="$current_ssh_port"
        fi
    fi

    if has_phase 4; then
        ask SSH_PORT "Confirm SSH port to open in firewall" "$SSH_PORT"
        echo ""
        echo -e "  ${C}?${RESET} ${W}Extra ports to open${RESET} ${D}(space-separated e.g. 8080 5432, or blank):${RESET}"
        echo -en "  ${D}> ${RESET}"
        read -r -a EXTRA_PORTS
        echo ""
        confirm "Enable Docker Swarm cluster ports?" "n" && OPEN_SWARM=true || OPEN_SWARM=false
        echo ""
    fi

    if has_phase 10; then
        if confirm "Install CapRover? (requires Docker)" "y"; then
            INSTALL_CAPROVER=true
            ask DOMAIN "Root domain for CapRover (e.g. example.com)" ""
            note "Required DNS: A captain.${DOMAIN} → this server IP"
            note "Required DNS: A *.${DOMAIN} → this server IP"
        fi
        echo ""
    fi

    # Summary
    echo ""
    echo -e "  ${C}───────────────────────── Summary ──────────────────────────${RESET}"
    has_phase 1  && echo -e "   ${OK} System update · hostname: ${W}${SERVER_HOSTNAME}${RESET} · tz: ${W}${SERVER_TIMEZONE}${RESET}"
    has_phase 2  && echo -e "   ${OK} Admin user: ${W}${ADMIN_USER}${RESET}"
    has_phase 3  && echo -e "   ${OK} SSH port: ${W}${SSH_PORT}${RESET} · key-only · root login disabled"
    has_phase 4  && echo -e "   ${OK} UFW firewall · extra ports: ${W}${EXTRA_PORTS[*]:-none}${RESET}"
    has_phase 5  && echo -e "   ${OK} Fail2ban"
    has_phase 6  && echo -e "   ${OK} Kernel sysctl hardening"
    has_phase 7  && echo -e "   ${OK} Rootkit detection"
    has_phase 8  && echo -e "   ${OK} Unattended upgrades"
    has_phase 9  && echo -e "   ${OK} Docker CE"
    ${INSTALL_CAPROVER:-false} && echo -e "   ${OK} CapRover · domain: ${W}${DOMAIN}${RESET}"
    has_phase 11 && echo -e "   ${OK} Monitoring tools"
    has_phase 12 && echo -e "   ${OK} Lynis audit"
    has_phase 13 && echo -e "   ${OK} Config backup"
    echo -e "  ${C}────────────────────────────────────────────────────────────${RESET}"
    echo ""

    confirm "Start the wizard?" "y" || { echo -e "\n${Y}  Aborted — no changes made.${RESET}\n"; exit 0; }
}

# ─── PHASES ───────────────────────────────────────────────────────────────────

phase_system_update() {
    banner "Phase 1 · System Update & Hostname"
    info "Updating package lists..."
    run apt-get update
    ok "Package lists updated"
    info "Upgrading packages (may take a few minutes)..."
    DEBIAN_FRONTEND=noninteractive run apt-get upgrade -y
    ok "Packages upgraded"
    run apt-get autoremove -y
    ok "Cleanup done"
    info "Setting hostname: ${SERVER_HOSTNAME}"
    run hostnamectl set-hostname "$SERVER_HOSTNAME"
    grep -q "$SERVER_HOSTNAME" /etc/hosts || echo "127.0.1.1 $SERVER_HOSTNAME" >> /etc/hosts
    ok "Hostname: $(hostnamectl --static)"
    info "Setting timezone: ${SERVER_TIMEZONE}"
    timedatectl set-timezone "$SERVER_TIMEZONE" >> "$LOG_FILE" 2>&1 && ok "Timezone set" || warn "Invalid timezone: ${SERVER_TIMEZONE}"
    ok "Phase 1 complete"
}

phase_create_user() {
    banner "Phase 2 · Create Non-Root Admin User"
    if id "$ADMIN_USER" &>/dev/null; then
        warn "User '${ADMIN_USER}' already exists — skipping"
    else
        info "Creating user: ${ADMIN_USER}"
        echo ""
        echo -e "  ${Y}⚠  Set a strong password for ${ADMIN_USER}:${RESET}"
        adduser --gecos "" "$ADMIN_USER"
        ok "User '${ADMIN_USER}' created"
    fi
    usermod -aG sudo "$ADMIN_USER"
    ok "${ADMIN_USER} has sudo privileges"
    ok "Phase 2 complete"
}

phase_ssh_hardening() {
    banner "Phase 3 · SSH Hardening"
    local sshd_conf="/etc/ssh/sshd_config"
    local original_port
    original_port=$(grep -E "^Port " "$sshd_conf" | awk '{print $2}' | head -n 1 || true)
    original_port=${original_port:-22}
    [[ ! -f "${sshd_conf}.bak" ]] && cp "$sshd_conf" "${sshd_conf}.bak" && ok "Backup: ${sshd_conf}.bak"

    info "Installing SSH key for ${ADMIN_USER}..."
    local ssh_dir="/home/${ADMIN_USER}/.ssh"
    mkdir -p "$ssh_dir"
    chmod 700 "$ssh_dir"
    echo "$SSH_PUB_KEY" > "${ssh_dir}/authorized_keys"
    chmod 600 "${ssh_dir}/authorized_keys"
    chown -R "${ADMIN_USER}:${ADMIN_USER}" "$ssh_dir"
    ok "SSH key installed"

    # Pre-open the new port in UFW if it exists, to prevent lockout
    if command -v ufw &>/dev/null; then
        ufw allow "${SSH_PORT}/tcp" comment "SSH Temp" >> "$LOG_FILE" 2>&1
    fi

    info "Writing hardened sshd_config (port ${SSH_PORT})..."
    cat > "$sshd_conf" <<SSHEOF
# ======================================================
# Hardened SSH — generated by forge v${VERSION}
# ======================================================
Protocol 2
Port ${SSH_PORT}

PermitRootLogin no
PasswordAuthentication no
KbdInteractiveAuthentication no
ChallengeResponseAuthentication no
PermitEmptyPasswords no
PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys

AllowUsers ${ADMIN_USER}
MaxAuthTries 3
MaxSessions 5
LoginGraceTime 30

X11Forwarding no
AllowAgentForwarding no
AllowTcpForwarding no

ClientAliveInterval 300
ClientAliveCountMax 2

UsePAM yes
PrintMotd no
AcceptEnv LANG LC_*
Subsystem sftp /usr/lib/openssh/sftp-server
SSHEOF

    # Handle ssh.socket (modern Ubuntu/systemd)
    if systemctl is-active --quiet ssh.socket; then
        info "Switching from ssh.socket to persistent ssh.service..."
        systemctl stop ssh.socket >> "$LOG_FILE" 2>&1 || true
        systemctl disable ssh.socket >> "$LOG_FILE" 2>&1 || true
        systemctl mask ssh.socket >> "$LOG_FILE" 2>&1 || true
    fi

    if systemctl restart ssh >> "$LOG_FILE" 2>&1; then
        systemctl enable ssh >> "$LOG_FILE" 2>&1 || true
        ok "SSH restarted on port ${SSH_PORT}"
    else
        error "SSH restart failed — restoring backup"
        cp "${sshd_conf}.bak" "$sshd_conf"
        systemctl restart ssh
        return 1
    fi

    echo ""
    echo -e "  ${R}${BOLD}OPEN A NEW TERMINAL NOW AND TEST:${RESET}"
    echo -e "  ${W}  ssh -p ${SSH_PORT} ${ADMIN_USER}@$(hostname -I | awk '{print $1}')${RESET}"
    echo -e "  ${Y}  ⚠  Do NOT close this session until login is confirmed!${RESET}"
    echo -e "  ${D}  (If you get 'Connection refused', you MUST open port ${SSH_PORT}${RESET}"
    echo -e "  ${D}   in your VPS provider's Cloud Console / Security Groups)${RESET}"
    echo ""
    pause

    local success=true
    if confirm "Did SSH login on port ${SSH_PORT} work?" "y"; then
        ok "SSH confirmed — hardening locked in"
    else
        success=false
        warn "Reverting SSH config..."
        if [[ -f "${sshd_conf}.bak" ]]; then
            cp "${sshd_conf}.bak" "$sshd_conf"

            # If we masked ssh.socket, unmask it on revert
            if systemctl list-unit-files | grep -q "^ssh.socket.*masked"; then
                systemctl unmask ssh.socket >> "$LOG_FILE" 2>&1 || true
                systemctl enable ssh.socket >> "$LOG_FILE" 2>&1 || true
                systemctl start ssh.socket >> "$LOG_FILE" 2>&1 || true
                systemctl stop ssh >> "$LOG_FILE" 2>&1 || true
            else
                systemctl restart ssh
            fi

            SSH_PORT="$original_port"
            ok "Original sshd_config restored (Port ${SSH_PORT})"
        else
            error "No backup found! SSH might be in an inconsistent state."
        fi
    fi

    echo ""
    if $success; then
        echo -e "  ${D}Add to your LOCAL ~/.ssh/config:${RESET}"
        echo -e "  ${C}  Host $(hostname -s)${RESET}"
        echo -e "  ${C}    HostName $(hostname -I | awk '{print $1}')${RESET}"
        echo -e "  ${C}    User ${ADMIN_USER}${RESET}"
        echo -e "  ${C}    Port ${SSH_PORT}${RESET}"
        echo -e "  ${C}    IdentityFile ~/.ssh/id_ed25519${RESET}"
        echo ""
        ok "Phase 3 complete (SSH Hardened)"
    else
        warn "Phase 3 finished with revert (SSH on port ${SSH_PORT})"
    fi
}

phase_ufw() {
    banner "Phase 4 · UFW Firewall"
    DEBIAN_FRONTEND=noninteractive run apt-get install -y ufw
    ufw --force default deny incoming  >> "$LOG_FILE" 2>&1
    ufw --force default allow outgoing >> "$LOG_FILE" 2>&1
    ok "Default policies: deny in / allow out"
    ufw allow "${SSH_PORT}/tcp" comment "SSH"   >> "$LOG_FILE" 2>&1 && ok "SSH port ${SSH_PORT} open"
    ufw allow 80/tcp  comment "HTTP"            >> "$LOG_FILE" 2>&1 && ok "HTTP (80) open"
    ufw allow 443/tcp comment "HTTPS"           >> "$LOG_FILE" 2>&1 && ok "HTTPS (443) open"
    ${INSTALL_CAPROVER:-false} && { ufw allow 3000/tcp comment "CapRover" >> "$LOG_FILE" 2>&1 && ok "CapRover (3000) open"; }
    if $OPEN_SWARM; then
        for p in "2377/tcp:Docker Swarm" "7946/tcp:Docker Nodes" "7946/udp:Docker Nodes" "4789/udp:Docker Overlay"; do
            ufw allow "${p%%:*}" comment "${p##*:}" >> "$LOG_FILE" 2>&1
        done
        ok "Docker Swarm ports open"
    fi
    for port in "${EXTRA_PORTS[@]}"; do
        [[ -z "$port" ]] && continue
        ufw allow "${port}/tcp" comment "Custom" >> "$LOG_FILE" 2>&1 && ok "Port ${port} open"
    done
    ufw --force enable >> "$LOG_FILE" 2>&1 && ok "UFW enabled"
    echo ""; ufw status verbose; echo ""
    ok "Phase 4 complete"
}

phase_fail2ban() {
    banner "Phase 5 · Fail2ban"
    DEBIAN_FRONTEND=noninteractive run apt-get install -y fail2ban
    cp /etc/fail2ban/jail.conf /etc/fail2ban/jail.local
    cat > /etc/fail2ban/jail.d/sshd-custom.conf <<F2BEOF
[sshd]
enabled  = true
port     = ${SSH_PORT}
filter   = sshd
logpath  = /var/log/auth.log
maxretry = 3
bantime  = 3600
findtime = 600
F2BEOF
    systemctl start fail2ban  >> "$LOG_FILE" 2>&1
    systemctl enable fail2ban >> "$LOG_FILE" 2>&1
    ok "fail2ban running — 3 tries → 1hr ban on port ${SSH_PORT}"
    echo ""; fail2ban-client status sshd 2>/dev/null || true; echo ""
    ok "Phase 5 complete"
}

phase_kernel_hardening() {
    banner "Phase 6 · Kernel / sysctl Hardening"
    cat >> /etc/sysctl.conf <<SYSCTL

# ── forge v${VERSION}: Network Security ──────────────────────────────────
net.ipv4.ip_forward = 1
net.ipv4.tcp_syncookies = 1
net.ipv4.conf.all.accept_source_route = 0
net.ipv6.conf.all.accept_source_route = 0
net.ipv4.conf.all.rp_filter = 1
net.ipv4.conf.default.rp_filter = 1
net.ipv4.icmp_echo_ignore_broadcasts = 1
net.ipv4.conf.all.accept_redirects = 0
net.ipv6.conf.all.accept_redirects = 0
net.ipv4.conf.all.send_redirects = 0
net.ipv4.conf.all.log_martians = 1
net.ipv4.tcp_rfc1337 = 1
fs.file-max = 65535
SYSCTL
    sysctl -p >> "$LOG_FILE" 2>&1
    ok "sysctl parameters applied"
    ok "Phase 6 complete"
}

phase_rootkit() {
    banner "Phase 7 · Rootkit Detection"
    DEBIAN_FRONTEND=noninteractive run apt-get install -y rkhunter chkrootkit
    rkhunter --update  >> "$LOG_FILE" 2>&1 || true
    rkhunter --propupd >> "$LOG_FILE" 2>&1 || true
    ok "rkhunter database updated"
    if confirm "Run rootkit scan now? (~2 min)" "y"; then
        echo ""
        rkhunter --check --skip-keypress --report-warnings-only 2>&1 | tee -a "$LOG_FILE" | grep -E "(Warning|Rootkit|Suspicious|Found)" || echo -e "  ${G}  No warnings found.${RESET}"
        echo ""
        chkrootkit 2>&1 | tee -a "$LOG_FILE" | grep -v "not infected" | grep -v "^$" | head -20 || true
    else
        skip "Rootkit scan — run manually: sudo rkhunter --check --skip-keypress"
    fi
    ok "Phase 7 complete"
}

phase_auto_updates() {
    banner "Phase 8 · Automatic Security Updates"
    DEBIAN_FRONTEND=noninteractive run apt-get install -y unattended-upgrades apt-listchanges
    cat > /etc/apt/apt.conf.d/50unattended-upgrades <<UUEOF
Unattended-Upgrade::Allowed-Origins {
    "\${distro_id}:\${distro_codename}";
    "\${distro_id}:\${distro_codename}-security";
    "\${distro_id}ESMApps:\${distro_codename}-apps-security";
    "\${distro_id}ESM:\${distro_codename}-infra-security";
};
Unattended-Upgrade::AutoFixInterruptedDpkg "true";
Unattended-Upgrade::MinimalSteps "true";
Unattended-Upgrade::Remove-Unused-Dependencies "true";
Unattended-Upgrade::Automatic-Reboot "false";
UUEOF
    cat > /etc/apt/apt.conf.d/20auto-upgrades <<UUEOF2
APT::Periodic::Update-Package-Lists "1";
APT::Periodic::Unattended-Upgrade "1";
APT::Periodic::AutocleanInterval "7";
UUEOF2
    systemctl enable unattended-upgrades >> "$LOG_FILE" 2>&1
    systemctl start  unattended-upgrades >> "$LOG_FILE" 2>&1
    ok "Automatic security upgrades enabled"
    ok "Phase 8 complete"
}

phase_docker() {
    banner "Phase 9 · Docker CE"
    if command -v docker &>/dev/null; then
        ok "Docker already installed: $(docker --version)"; return
    fi
    apt-get remove -y docker docker-engine docker.io containerd runc >> "$LOG_FILE" 2>&1 || true
    DEBIAN_FRONTEND=noninteractive run apt-get install -y ca-certificates curl gnupg lsb-release
    mkdir -p /etc/apt/keyrings
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
    chmod a+r /etc/apt/keyrings/docker.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" \
        | tee /etc/apt/sources.list.d/docker.list > /dev/null
    run apt-get update
    DEBIAN_FRONTEND=noninteractive run apt-get install -y \
        docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
    systemctl start  docker >> "$LOG_FILE" 2>&1
    systemctl enable docker >> "$LOG_FILE" 2>&1
    ok "Docker CE installed and running"
    [[ -n "$ADMIN_USER" ]] && id "$ADMIN_USER" &>/dev/null && usermod -aG docker "$ADMIN_USER" && ok "${ADMIN_USER} added to docker group"
    docker --version
    ok "Phase 9 complete"
}

phase_caprover() {
    banner "Phase 10 · CapRover"
    command -v docker &>/dev/null || { error "Docker not installed. Run: sudo forge phase 9"; return 1; }
    [[ -z "$DOMAIN" ]] && ask DOMAIN "Root domain" ""
    echo ""
    echo -e "  ${Y}⚠  Required DNS records:${RESET}"
    echo -e "  ${W}  A  captain.${DOMAIN}  →  $(hostname -I | awk '{print $1}')${RESET}"
    echo -e "  ${W}  A  *.${DOMAIN}        →  $(hostname -I | awk '{print $1}')${RESET}"
    echo ""
    if confirm "DNS configured and ready?" "y"; then
        docker run -d \
            -p 80:80 -p 443:443 -p 3000:3000 \
            -e ACCEPTED_TERMS=true \
            -v /var/run/docker.sock:/var/run/docker.sock \
            -v /captain:/captain \
            --name caprover \
            --restart unless-stopped \
            caprover/caprover >> "$LOG_FILE" 2>&1
        ok "CapRover container started"
        info "Waiting 30 seconds for init..."
        sleep 30
        echo ""
        echo -e "  ${G}${BOLD}CapRover ready!${RESET}"
        echo -e "  ${D}Dashboard:${RESET} ${W}http://captain.${DOMAIN}:3000${RESET}"
        echo -e "  ${D}Default Pass:${RESET} ${G}captain42${RESET} ${D}(Change immediately after login)${RESET}"
        echo -e "  ${D}Note:${RESET} ${D}After running ${W}caprover serversetup${D}, you can access via port 80/443.${RESET}"
        echo ""
        echo -e "  ${D}CLI setup:${RESET} ${W}npm install -g caprover && caprover serversetup${RESET}"
    else
        skip "CapRover — run later: sudo forge phase 10"
    fi
    ok "Phase 10 complete"
}

phase_monitoring() {
    banner "Phase 11 · Monitoring Tools"
    DEBIAN_FRONTEND=noninteractive run apt-get install -y htop iotop nethogs ncdu logwatch net-tools
    ok "Installed: htop · iotop · nethogs · ncdu · logwatch · net-tools"
    echo ""
    echo -e "   ${C}htop${RESET}      CPU/memory monitor"
    echo -e "   ${C}iotop${RESET}     Disk I/O per process"
    echo -e "   ${C}nethogs${RESET}   Network traffic per process"
    echo -e "   ${C}ncdu /${RESET}    Disk usage explorer"
    echo -e "   ${C}ss -tulpn${RESET} Open ports"
    echo ""
    ok "Phase 11 complete"
}

phase_lynis() {
    banner "Phase 12 · Lynis Security Audit"
    DEBIAN_FRONTEND=noninteractive run apt-get install -y lynis
    if confirm "Run full Lynis audit now? (~3 min)" "y"; then
        echo ""
        lynis audit system --quiet 2>&1 | tee -a "$LOG_FILE" | grep -E "(WARNING|SUGGESTION|Hardening index)" | head -40 || true
        echo ""
        note "Full report: $LOG_FILE"
        note "Re-run anytime: sudo lynis audit system"
    else
        skip "Lynis audit — run manually: sudo lynis audit system"
    fi
    ok "Phase 12 complete"
}

phase_backup() {
    banner "Phase 13 · Config Backup"
    local backup_file="/root/vps-config-$(date +%Y%m%d-%H%M%S).tar.gz"
    tar -czf "$backup_file" \
        /etc/ssh/sshd_config \
        /etc/ufw/ \
        /etc/fail2ban/ \
        /etc/sysctl.conf \
        /etc/apt/apt.conf.d/50unattended-upgrades \
        "$LOG_FILE" \
        2>/dev/null || true
    ok "Backup: ${backup_file}"
    echo ""
    echo -e "  ${Y}⚠  Copy this offsite:${RESET}"
    echo -e "  ${W}  scp root@$(hostname -I | awk '{print $1}'):${backup_file} ./vps-backup.tar.gz${RESET}"
    echo ""
    ok "Phase 13 complete"
}

