# ─── CMD: Reset ───────────────────────────────────────────────────────────────
cmd_reset() {
    require_root reset
    banner "Server Reset / Restore"
    echo -e "  ${Y}⚠  WARNING: This will revert SSH config and remove the admin user.${RESET}"
    echo ""

    if ! confirm "Reset server configuration back to default?" "n"; then
        echo -e "  ${D}Reset cancelled.${RESET}"
        return
    fi

    # 1. Detect Admin User (while sshd_config is still modified)
    local sshd_conf="/etc/ssh/sshd_config"
    local user_to_remove
    # Try AllowUsers first
    user_to_remove=$(grep -E "^AllowUsers " "$sshd_conf" | awk '{print $2}' | head -n 1 || true)

    # If not found, look for common names or ask
    if [[ -z "$user_to_remove" ]]; then
        if [[ -d "/home/deploy" ]]; then
            user_to_remove="deploy"
        fi
    fi

    # 2. Revert SSH
    if [[ -f "${sshd_conf}.bak" ]]; then
        info "Restoring SSH config from backup..."
        cp "${sshd_conf}.bak" "$sshd_conf"

        # Restore ssh.socket if it was masked (common in modern Ubuntu)
        if systemctl list-unit-files | grep -q "^ssh.socket.*masked"; then
            info "Restoring ssh.socket activation..."
            systemctl unmask ssh.socket >> "$LOG_FILE" 2>&1 || true
            systemctl enable ssh.socket >> "$LOG_FILE" 2>&1 || true
            systemctl start ssh.socket >> "$LOG_FILE" 2>&1 || true
            systemctl stop ssh >> "$LOG_FILE" 2>&1 || true
        else
            systemctl restart ssh
        fi
        ok "SSH config restored"
    else
        warn "No SSH backup found (/etc/ssh/sshd_config.bak). Keeping current config."
    fi

    # 3. Reset Firewall
    if command -v ufw &>/dev/null; then
        info "Resetting UFW firewall..."
        ufw --force reset &>/dev/null
        ufw --force disable &>/dev/null
        ok "UFW reset and disabled"
    fi

    # 4. Remove Admin User
    if [[ -n "$user_to_remove" ]]; then
        if confirm "Remove user '${user_to_remove}' and their home directory?" "y"; then
            deluser --remove-home "$user_to_remove" &>/dev/null || true
            ok "User '${user_to_remove}' removed"
        fi
    fi

    # 5. Remove fail2ban custom config
    if [[ -f "/etc/fail2ban/jail.d/sshd-custom.conf" ]]; then
        rm -f "/etc/fail2ban/jail.d/sshd-custom.conf"
        systemctl restart fail2ban &>/dev/null || true
        ok "Fail2ban custom config removed"
    fi

    # 6. Optional Docker/CapRover removal
    if command -v docker &>/dev/null; then
        if confirm "Remove Docker and all containers/data?" "n"; then
            info "Stopping containers and purging Docker..."
            docker ps -aq | xargs docker rm -f &>/dev/null || true
            apt-get purge -y docker-ce docker-ce-cli containerd.io &>/dev/null || true
            rm -rf /var/lib/docker
            ok "Docker removed"
        fi
    fi

    # 7. Remove Swap file
    if [[ -f "/swapfile" ]]; then
        if confirm "Remove swap file and restore fstab?" "n"; then
            info "Disabling and removing /swapfile..."
            swapoff /swapfile >> "$LOG_FILE" 2>&1 || true
            rm -f /swapfile
            sed -i '/\/swapfile/d' /etc/fstab
            ok "Swap file removed"
        fi
    fi

    # 8. Remove WireGuard
    if [[ -d "/etc/wireguard" ]]; then
        if confirm "Remove WireGuard VPN configuration and keys?" "n"; then
            info "Stopping and removing WireGuard..."
            systemctl stop wg-quick@wg0 >> "$LOG_FILE" 2>&1 || true
            systemctl disable wg-quick@wg0 >> "$LOG_FILE" 2>&1 || true
            rm -rf /etc/wireguard
            rm -f /etc/sysctl.d/99-wireguard.conf
            rm -f /root/wireguard-client.conf
            ufw delete allow 51820/udp >> "$LOG_FILE" 2>&1 || true
            ok "WireGuard removed"
        fi
    fi

    # 9. Remove Heal System
    if [[ -f "/usr/local/bin/forge-heal" ]]; then
        if confirm "Remove automated heal system?" "n"; then
            info "Disabling heal system..."
            systemctl stop forge-heal.timer >> "$LOG_FILE" 2>&1 || true
            systemctl disable forge-heal.timer >> "$LOG_FILE" 2>&1 || true
            rm -f /etc/systemd/system/forge-heal.*
            rm -f /usr/local/bin/forge-heal
            systemctl daemon-reload
            ok "Heal system removed"
        fi
    fi

    echo ""
    ok "Reset complete. Server is back to (mostly) default state."
    echo ""
}

